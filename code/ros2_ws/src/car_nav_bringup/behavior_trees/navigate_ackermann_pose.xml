<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="4" name="AckermannNavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
        <FollowPath path="{path}" controller_id="FollowPath" goal_checker_id="pose_goal_checker"/>
      </PipelineSequence>
      <ReactiveFallback name="RecoveryFallback"><GoalUpdated/><RoundRobin name="RecoveryActions"><ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/><BackUp backup_dist="-0.15" backup_speed="0.05"/><Wait wait_duration="1.0"/></RoundRobin></ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
