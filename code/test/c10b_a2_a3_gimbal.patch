+						/*
+						 * Extended USB command, backwards compatible with the normal
+						 * 11-byte velocity frame:
+						 *   bytes 1..2 = A2 pulse, bytes 5..6 = A3 pulse (microseconds).
+						 * Zero means leave that axis unchanged.  Normal ROS velocity
+						 * senders put zero in these unused fields and remain unaffected.
+						 */
+						u16 a2 = ((u16)Receive_Data.buffer[1] << 8) | Receive_Data.buffer[2];
+						u16 a3 = ((u16)Receive_Data.buffer[5] << 8) | Receive_Data.buffer[6];
+						if (a2 >= 900 && a2 <= 2100) Gimbal_A2_PWM = a2;
